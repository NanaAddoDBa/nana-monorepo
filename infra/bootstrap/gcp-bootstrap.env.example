# Copy this file to gcp-bootstrap.env and adjust values before running.
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west3
TF_STATE_BUCKET=your-project-tf-state
ARTIFACT_REGISTRY_REPOSITORY=apps

GITHUB_REPOSITORY=your-github-user/your-repo
GITHUB_DEPLOY_BRANCH=master
WIF_POOL_ID=github-actions
WIF_PROVIDER_ID=github

TERRAFORM_SERVICE_ACCOUNT_ID=terraform-deployer
DEPLOY_SERVICE_ACCOUNT_ID=github-cloud-run-deployer
TERRAFORM_CUSTOM_ROLE_ID=terraformCloudRunManager
MONTHLY_BUDGET_AMOUNT=5
